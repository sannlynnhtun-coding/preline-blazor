@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="surface-card max-w-2xl p-6">
    <h1 class="text-xl font-semibold text-[var(--text-strong)]">Something went wrong.</h1>
    <p class="mt-2 text-sm text-[var(--text-muted)]">An error occurred while processing this request.</p>

    @if (ShowRequestId)
    {
        <p class="mt-3 text-sm text-[var(--text-muted)]">
            <strong class="text-[var(--text-strong)]">Request ID:</strong>
            <code class="rounded bg-[var(--surface-subtle)] px-2 py-1">@RequestId</code>
        </p>
    }

    <div class="mt-5 rounded-lg border border-[var(--border-color)] bg-[var(--surface-subtle)] p-4 text-sm text-[var(--text-muted)]">
        Enable the <strong class="text-[var(--text-strong)]">Development</strong> environment locally to see detailed exception information.
    </div>
</div>

@code {
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = System.Diagnostics.Activity.Current?.Id;
}

