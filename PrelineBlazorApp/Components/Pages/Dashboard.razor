@page "/"
@page "/dashboard"
@inject IDashboardDataService DashboardData

<PageTitle>Dashboard</PageTitle>

<PageHeading Title="Dashboard Overview" Description="Key commercial health signals across growth, revenue, and customer operations.">
    <Actions>
        <UiButton Variant="UiVariant.Secondary">Download Report</UiButton>
        <UiButton Variant="UiVariant.Primary">Create Alert</UiButton>
    </Actions>
</PageHeading>

<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    @foreach (var kpi in Kpis)
    {
        <MetricCard Label="@kpi.Label" Value="@kpi.Value" Delta="@kpi.Delta" DeltaPositive="@kpi.DeltaPositive" Hint="@kpi.Hint" />
    }
</div>

<div class="mt-4 grid gap-4 xl:grid-cols-3">
    <UiCard Class="xl:col-span-2" Title="Revenue Trajectory" Description="Monthly recurring revenue over the last 12 months.">
        <Highchart ChartId="revenue-overview" ChartKind="areaspline" Height="330px" OptionsJson="@RevenueChartJson" />
    </UiCard>

    <UiCard Title="Acquisition Mix" Description="How users discover and convert.">
        <Highchart ChartId="channel-mix" ChartKind="pie" Height="330px" OptionsJson="@ChannelChartJson" />
    </UiCard>
</div>

<div class="mt-4 grid gap-4 xl:grid-cols-3">
    <UiCard Class="xl:col-span-2" Title="Recent Orders" Description="Operational queue for recently updated orders.">
        <TableControls SearchTerm="@OrdersQuery.SearchTerm"
                       SearchTermChanged="OnOrdersSearchChanged"
                       SearchPlaceholder="Search order, customer, amount, status..."
                       FilteredCount="@FilteredOrders.Count"
                       CurrentPage="@OrdersQuery.CurrentPage"
                       PageSize="@OrdersQuery.PageSize"
                       PageSizeOptions="@OrdersQuery.PageSizeOptions"
                       PageChanged="OnOrdersPageChanged"
                       PageSizeChanged="OnOrdersPageSizeChanged"
                       ResultLabel="orders" />

        <UiTable Header="@HeaderTemplate">
            @if (PagedOrders.Count == 0)
            {
                <tr>
                    <td colspan="5" class="px-4 py-8 text-center text-sm text-[var(--text-muted)]">No orders match your search.</td>
                </tr>
            }
            else
            {
                @foreach (var order in PagedOrders)
                {
                    <tr>
                        <td>@order.OrderNo</td>
                        <td>@order.Customer</td>
                        <td>@order.Amount</td>
                        <td><UiBadge Text="@order.Status" Tone="@ToneForStatus(order.Status)" /></td>
                        <td>@order.CreatedOn.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
            }
        </UiTable>
    </UiCard>

    <UiCard Title="Operational Alerts" Description="Latest automated health checks.">
        <UiListGroup Items="@AlertItems" />
    </UiCard>
</div>

@code {
    private readonly TableQueryState OrdersQuery = new() { PageSize = 5, PageSizeOptions = [5, 10, 20] };

    private IReadOnlyList<KpiMetric> Kpis { get; set; } = [];
    private IReadOnlyList<OrderRow> Orders { get; set; } = [];
    private IReadOnlyList<AlertRow> Alerts { get; set; } = [];

    private string RevenueChartJson { get; set; } = "{}";
    private string ChannelChartJson { get; set; } = "{}";

    private IReadOnlyList<OrderRow> FilteredOrders => Orders
        .Where(OrderMatches)
        .ToList();

    private IReadOnlyList<OrderRow> PagedOrders
    {
        get
        {
            var filtered = FilteredOrders;
            OrdersQuery.ClampPage(filtered.Count);
            return filtered
                .Skip((OrdersQuery.CurrentPage - 1) * OrdersQuery.PageSize)
                .Take(OrdersQuery.PageSize)
                .ToList();
        }
    }

    private RenderFragment HeaderTemplate => @<tr>
        <th>Order</th>
        <th>Customer</th>
        <th>Amount</th>
        <th>Status</th>
        <th>Date</th>
    </tr>;

    private IReadOnlyList<UiListGroupItem> AlertItems => Alerts
        .Select(alert => new UiListGroupItem(alert.Title, alert.Message, ToneForStatus(alert.Severity)))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        Kpis = await DashboardData.GetKpisAsync();
        Orders = await DashboardData.GetOrdersAsync();
        Alerts = await DashboardData.GetAlertsAsync();

        var revenue = await DashboardData.GetRevenueSeriesAsync();
        var channels = await DashboardData.GetChannelSharesAsync();

        RevenueChartJson = ChartOptionsFactory.CreateRevenueLineOptions(revenue);
        ChannelChartJson = ChartOptionsFactory.CreateDonutOptions(channels);
    }

    private Task OnOrdersSearchChanged(string value)
    {
        OrdersQuery.SearchTerm = value;
        OrdersQuery.ResetPage();
        return Task.CompletedTask;
    }

    private Task OnOrdersPageChanged(int page)
    {
        OrdersQuery.CurrentPage = page;
        return Task.CompletedTask;
    }

    private Task OnOrdersPageSizeChanged(int pageSize)
    {
        OrdersQuery.PageSize = pageSize;
        OrdersQuery.ResetPage();
        return Task.CompletedTask;
    }

    private bool OrderMatches(OrderRow order)
    {
        if (string.IsNullOrWhiteSpace(OrdersQuery.SearchTerm))
        {
            return true;
        }

        var query = OrdersQuery.SearchTerm.Trim();
        return order.OrderNo.Contains(query, StringComparison.OrdinalIgnoreCase)
            || order.Customer.Contains(query, StringComparison.OrdinalIgnoreCase)
            || order.Amount.Contains(query, StringComparison.OrdinalIgnoreCase)
            || order.Status.Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private static UiTone ToneForStatus(string status) => status.ToLowerInvariant() switch
    {
        "fulfilled" => UiTone.Success,
        "processing" => UiTone.Info,
        "pending" => UiTone.Warning,
        "cancelled" => UiTone.Danger,
        "critical" => UiTone.Danger,
        "warning" => UiTone.Warning,
        "info" => UiTone.Info,
        _ => UiTone.Neutral
    };
}
