@inject INavigationService NavigationService
@{
    var currentPath = Context.Request.Path.Value ?? "/";
    var breadcrumbs = NavigationService.BuildBreadcrumbs(currentPath);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Preline MVC</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
</head>
<body class="min-h-screen bg-[var(--surface-ghost)] text-[var(--text-strong)]">
    <div class="min-h-screen bg-[var(--surface-ghost)] text-[var(--text-strong)]">
        <aside id="admin-sidebar" class="hs-overlay [--auto-close:lg] hs-overlay-open:translate-x-0 fixed inset-y-0 start-0 z-[60] w-72 -translate-x-full border-e border-[var(--border-color)] bg-[var(--surface)] transition-transform duration-300 lg:translate-x-0">
            <div class="flex h-full flex-col">
                <div class="flex items-center justify-between border-b border-[var(--border-color)] px-4 py-4">
                    <div>
                        <p class="text-xs uppercase tracking-[0.2em] text-[var(--text-muted)]">Preline Admin</p>
                        <h2 class="mt-1 text-lg font-semibold">SaaS Ops (MVC)</h2>
                    </div>
                    <button type="button" class="btn-ghost lg:hidden" data-hs-overlay="#admin-sidebar" aria-label="Close sidebar">
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                    </button>
                </div>

                <nav class="flex-1 space-y-6 overflow-y-auto px-3 py-4">
                    @foreach (var navGroup in NavigationService.Menu.GroupBy(x => x.Section))
                    {
                        <div>
                            <p class="px-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--text-muted)]">@navGroup.Key</p>
                            <ul class="mt-2 space-y-1">
                                @foreach (var item in navGroup)
                                {
                                    var isActive = (currentPath == item.Href) || (currentPath == "/" && item.Href == "/");
                                    <li>
                                        <a href="@item.Href" class="menu-item @(isActive ? "menu-item-active" : "")">
                                            <span class="menu-item-icon">@IconHelper.GetIcon(item.Icon)</span>
                                            <span class="min-w-0 flex-1 truncate">@item.Title</span>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </nav>

                <div class="border-t border-[var(--border-color)] p-3">
                    <div class="rounded-lg border border-[var(--border-color)] bg-[var(--surface-subtle)] px-3 py-2">
                        <p class="text-xs text-[var(--text-muted)]">System status</p>
                        <div class="mt-1 flex items-center justify-between text-sm">
                            <span>All services healthy</span>
                            <span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <div class="min-h-screen lg:ms-72">
            <header class="sticky top-0 z-40 border-b border-[var(--border-color)] bg-[var(--surface)]/90 backdrop-blur">
                <div class="flex flex-col gap-3 px-4 py-3 lg:px-6">
                    <div class="flex items-center justify-between gap-3">
                        <div class="flex items-center gap-2">
                            <button type="button" class="btn-secondary lg:hidden" data-hs-overlay="#admin-sidebar">Menu</button>
                            <ol class="hidden items-center gap-2 text-xs text-[var(--text-muted)] sm:flex">
                                @foreach (var crumb in breadcrumbs)
                                {
                                    <li class="flex items-center gap-2">
                                        @if (!string.IsNullOrWhiteSpace(crumb.Href))
                                        {
                                            <a class="hover:text-[var(--text-strong)]" href="@crumb.Href">@crumb.Title</a>
                                        }
                                        else
                                        {
                                            <span>@crumb.Title</span>
                                        }
                                        <span class="text-[var(--border-color)]">/</span>
                                    </li>
                                }
                            </ol>
                        </div>

                        <div class="flex items-center gap-2">
                            <div class="hs-dropdown relative inline-flex">
                                <button id="quick-actions" type="button" class="btn-secondary" aria-haspopup="menu" aria-expanded="false">
                                    Quick Actions
                                </button>
                                <div class="hs-dropdown-menu hs-dropdown-open:opacity-100 mt-2 hidden w-52 rounded-lg border border-[var(--border-color)] bg-[var(--surface)] p-1 opacity-0 shadow-sm transition" role="menu" aria-orientation="vertical" aria-labelledby="quick-actions">
                                    <a class="dropdown-item" href="/Home/Customers">Create customer note</a>
                                    <a class="dropdown-item" href="/Home/Tasks">Assign task</a>
                                    <a class="dropdown-item" href="/Home/Billing">Review overdue invoice</a>
                                </div>
                            </div>
                            <button class="btn-ghost" title="Notifications">
                                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"></path>
                                    <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path>
                                </svg>
                            </button>
                            <div class="hs-dropdown relative inline-flex">
                                <button id="profile-menu" type="button" class="btn-ghost flex items-center gap-x-2" aria-haspopup="menu" aria-expanded="false">
                                    Mia Hudson
                                    <svg class="size-3" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6" /></svg>
                                </button>
                                <div class="hs-dropdown-menu hs-dropdown-open:opacity-100 mt-2 hidden w-44 rounded-lg border border-[var(--border-color)] bg-[var(--surface)] p-1 opacity-0 shadow-sm transition" role="menu" aria-orientation="vertical" aria-labelledby="profile-menu">
                                    <a class="dropdown-item" href="/Home/Settings">Appearance</a>
                                    <a class="dropdown-item" href="/Home/Team">Team profile</a>
                                    <a class="dropdown-item" href="/">Sign out</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
                        <div class="relative w-full xl:max-w-xl">
                            <span class="pointer-events-none absolute inset-y-0 start-3 flex items-center text-[var(--text-muted)]">
                                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
                            </span>
                            <input type="text" class="input-base ps-9" placeholder="Search customers, orders, tasks..." />
                        </div>

                        <div class="flex flex-wrap items-center gap-2">
                            <select id="theme-selector" class="input-base h-10 w-40 py-1 text-sm" onchange="window.dashboardTheme.setMode(this.value)">
                                <option value="system">System mode</option>
                                <option value="light">Light mode</option>
                                <option value="dark">Dark mode</option>
                            </select>

                            <select id="palette-selector" class="input-base h-10 w-44 py-1 text-sm" onchange="window.dashboardTheme.setPagePalette(window.location.pathname, this.value)">
                                <option value="">Page: use default</option>
                                <option value="slate">Page: Slate</option>
                                <option value="sky">Page: Sky</option>
                                <option value="emerald">Page: Emerald</option>
                                <option value="amber">Page: Amber</option>
                                <option value="rose">Page: Rose</option>
                            </select>

                            <a class="btn-secondary" href="/Home/Settings">Theme Settings</a>
                        </div>
                    </div>
                </div>
            </header>

            <main class="p-4 lg:p-6">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/js/vendor/highcharts.js" asp-append-version="true"></script>
    <script src="~/js/vendor/preline.js" asp-append-version="true"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const currentRoute = window.location.pathname;
            window.dashboardTheme.apply(currentRoute);

            // Sync selectors with current preference
            const pref = window.dashboardTheme.getPreference();
            const modeSelector = document.getElementById('theme-selector');
            if (modeSelector) modeSelector.value = pref.mode;

            const paletteSelector = document.getElementById('palette-selector');
            if (paletteSelector) {
                const normalized = currentRoute === '/' ? '/dashboard' : currentRoute;
                paletteSelector.value = pref.pagePaletteOverrides[normalized] || "";
            }
        });
    </script>
</body>
</html>
