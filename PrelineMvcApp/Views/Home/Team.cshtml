@using PrelineMvcApp.Models.Dashboard
@model IReadOnlyList<TeamMemberRow>
@{
    ViewData["Title"] = "Team";
}

<div class="mb-5 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
    <div>
        <h1 class="text-2xl font-semibold text-[var(--text-strong)]">Team Management</h1>
        <p class="mt-1 text-sm text-[var(--text-muted)]">Control workspace access and collaborator roles.</p>
    </div>
    <div class="flex items-center gap-2">
        <button type="button" class="btn-primary">Invite Member</button>
    </div>
</div>

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    @foreach (var member in Model)
    {
        <div class="surface-card p-5 group transition-all duration-300 hover:shadow-lg dark:hover:shadow-neutral-900/40">
            <div class="flex items-start justify-between">
                <div class="flex items-center gap-3">
                    <div class="size-12 rounded-full bg-[var(--surface-subtle)] flex items-center justify-center border border-[var(--border-color)]">
                        <span class="text-lg font-bold text-[var(--text-strong)] opacity-50">@member.Name[0]</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-[var(--text-strong)]">@member.Name</h4>
                        <p class="text-xs text-[var(--text-muted)]">@member.Role</p>
                    </div>
                </div>
                <span class="inline-flex items-center gap-x-1.5 py-1 px-2.5 rounded-full text-xs font-medium @(member.Status == "Online" ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-800/30 dark:text-emerald-500" : "bg-gray-100 text-gray-800 dark:bg-white/10 dark:text-white")">
                    @member.Status
                </span>
            </div>
            
            <div class="mt-8 pt-4 border-t border-[var(--border-color)] flex items-center justify-between text-xs text-[var(--text-muted)]">
                <span>Timezone: @member.Timezone</span>
                <button class="font-medium text-[var(--text-strong)] hover:underline opacity-0 group-hover:opacity-100 transition-opacity">Edit Role</button>
            </div>
        </div>
    }
</div>
